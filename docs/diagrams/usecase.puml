@startuml OmniPlayer_UseCase
!theme plain

title UseCase-диаграмма OmniPlayer

left to right direction

skinparam packageStyle rectangle

actor "Гость" as Guest
actor "Пользователь" as User
actor "Администратор" as Admin

package "Публичные функции" {
    usecase "Просмотр главной страницы" as UC1
    usecase "Просмотр списка комнат" as UC2
    usecase "Регистрация" as UC3
    usecase "Вход в систему" as UC4
}

package "Функции пользователя" {
    usecase "Создание комнаты" as UC5
    usecase "Присоединение к комнате" as UC6
    usecase "Управление очередью треков" as UC7
    usecase "Загрузка аудиофайла" as UC8
    usecase "Добавление трека по ссылке" as UC9
    usecase "Воспроизведение треков" as UC10
    usecase "Пауза/Возобновление" as UC11
    usecase "Пропуск трека" as UC12
    usecase "Отправка сообщения в чат" as UC13
    usecase "Просмотр участников комнаты" as UC14
    usecase "Включение/выключение голосовых вставок" as UC15
    usecase "Просмотр профиля" as UC16
}

package "Функции администратора" {
    usecase "Управление пользователями" as UC17
    usecase "Удаление пользователя" as UC18
    usecase "Изменение роли пользователя" as UC19
    usecase "Просмотр всех комнат" as UC20
    usecase "Закрытие комнаты" as UC21
    usecase "Удаление сообщения в чате" as UC22
    usecase "Блокировка пользователя в комнате" as UC23
    usecase "Просмотр журнала аудита" as UC24
}

Guest --> UC1
Guest --> UC2
Guest --> UC3
Guest --> UC4

User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11
User --> UC12
User --> UC13
User --> UC14
User --> UC15
User --> UC16

Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23
Admin --> UC24

note right of UC7
  Включает: добавление, удаление,
  изменение порядка треков
end note

note bottom of UC10
  Синхронизация через WebSocket
  Управление доступно только host
end note

note bottom of UC15
  TTS/RVC для озвучивания
  названий треков и системных сообщений
end note

@enduml

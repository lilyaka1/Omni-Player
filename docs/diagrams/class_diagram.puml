@startuml OmniPlayer_Class_Diagram
!theme plain

title Диаграмма классов OmniPlayer

skinparam classAttributeIconSize 0

package "Domain Models" {
  class User {
    +id: UUID
    +email: str
    +username: str
    +hashed_password: str
    +role: UserRole
    +avatar_url: str
    --
    +check_password()
    +set_password()
  }

  class Room {
    +id: UUID
    +name: str
    +description: str
    +password: str
    +host_id: UUID
    +is_public: bool
    +now_playing_track_id: UUID
    +playback_position: float
    +playback_state: PlaybackState
    +playback_generation: int
    --
    +start_playback()
    +pause_playback()
    +add_participant()
    +remove_participant()
  }

  class Track {
    +id: UUID
    +title: str
    +artist: str
    +duration: int
    +file_path: str
    +source_type: SourceType
    +external_id: str
    +cover_url: str
    +metadata: JSONB
  }

  class RoomTrack {
    +id: UUID
    +room_id: UUID
    +track_id: UUID
    +added_by: UUID
    +queue_order: int
    +status: TrackStatus
  }

  class Message {
    +id: UUID
    +room_id: UUID
    +user_id: UUID
    +content: str
  }

  class UserRoom {
    +user_id: UUID
    +room_id: UUID
    +is_active: bool
  }

  class AuditLog {
    +user_id: UUID
    +action: str
    +resource_type: str
    +resource_id: UUID
    +details: JSONB
  }
}

package "Services (Business Logic)" {
  class AuthService {
    +register()
    +login()
    +refresh_token()
    +logout()
  }

  class RoomService {
    +create_room()
    +join_room()
    +leave_room()
    +get_room_state()
  }

  class PlaybackController {
    +start_playback()
    +pause_playback()
    +seek()
    +next_track()
    +sync_position()
  }

  class QueueService {
    +add_track()
    +remove_track()
    +reorder()
    +get_current()
    +advance()
  }

  class VoiceInsertService {
    +synthesize()
    +queue_voice_insert()
    +get_voice_settings()
  }

  class TrackService {
    +upload_track()
    +get_metadata()
    +search()
  }
}

package "Routers (API Endpoints)" {
  class AuthRouter {
    +POST /auth/register
    +POST /auth/login
    +POST /auth/refresh
    +POST /auth/logout
    +GET /auth/me
  }

  class RoomRouter {
    +GET /rooms
    +POST /rooms
    +GET /rooms/{id}
    +POST /rooms/{id}/play
    +POST /rooms/{id}/pause
    +POST /rooms/{id}/next
  }

  class TrackRouter {
    +POST /tracks
    +GET /tracks/search
    +POST /rooms/{id}/tracks
  }

  class ChatRouter {
    +GET /rooms/{id}/messages
    +POST /rooms/{id}/messages
  }

  class AdminRouter {
    +GET /admin/users
    +PATCH /admin/users/{id}
    +DELETE /admin/users/{id}
    +GET /admin/audit
  }
}

package "WebSocket" {
  class RoomGateway {
    -connections: Dict
    -rooms: Dict
    --
    +connect()
    +disconnect()
    +broadcast()
    +handle_event()
  }

  class ChatHandler {
    +on_message()
    +broadcast()
  }
}

package "Middleware" {
  class AuditMiddleware {
    +async __call__()
    -log_request()
    -log_response()
  }

  class AuthMiddleware {
    +async __call__()
    -validate_token()
  }
}

package "Database" {
  class BaseModel {
    +id: UUID
    +created_at: datetime
    +updated_at: datetime
  }

  class Repository {
    +get()
    +create()
    +update()
    +delete()
    +list()
  }
}

User --> Room : host >
User --> Track : создает >
User --> Message : отправляет >
Room --> RoomTrack : содержит >
Room --> Message : собирает >
Track --> RoomTrack : добавляется в >
User "1" --> "*" UserRoom : состоит в >
UserRoom --> Room : присоединяется к >
Room "1" --> "0..1" RoomTrack : now_playing >

AuthService ..> User
RoomService ..> Room
RoomService ..> UserRoom
PlaybackController ..> Room
PlaybackController ..> RoomTrack
QueueService ..> RoomTrack
VoiceInsertService ..> Track
TrackService ..> Track

AuthRouter ..> AuthService
RoomRouter ..> RoomService
TrackRouter ..> TrackService

RoomGateway --> Room
RoomGateway --> RoomService

AuditMiddleware ..> AuditLog

BaseModel <|-- User
BaseModel <|-- Room
BaseModel <|-- Track
BaseModel <|-- RoomTrack
BaseModel <|-- Message
BaseModel <|-- AuditLog

note top of User
  Паттерн: Entity
  Хранит состояние пользователя
  Пароль хешируется через bcrypt
end note

note top of RoomService
  Паттерн: Service Layer
  Инкапсулирует бизнес-логику
  работы с комнатами
end note

note top of RoomGateway
  Паттерн: Observer
  Управляет подключениями
  и рассылкой событий
end note

@enduml
# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/omni_player

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# TTS Settings
TTS_AUDIO_DIR=./tts_audio
TTS_MODEL_DIR=./tts_models
TTS_MAX_CONCURRENT=2
PIPER_BIN=piper

# RVC Settings
RVC_ENABLED=true
RVC_MODEL_PATH=Kanye West - Weights Model/Kanye West (RVC) 1000 Epoch
RVC_CONFIG_PATH=
RVC_SPEAKER=0
RVC_CACHE_DIR=/tmp/rvc_cache
RVC_DEFAULT_PITCH=0
RVC_INDEX_RATE=0.75
RVC_PROTECT=0.33
MAX_CONCURRENT_RVC=2

# Streaming
MAX_BUFFER_SIZE=8192
BUFFER_TIMEOUT=30
FFMPEG_PATH=ffmpeg

# HLS
HLS_ENABLED=true
HLS_SEGMENT_DURATION=6
HLS_USE_S3=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173